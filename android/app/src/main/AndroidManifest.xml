<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- App Shortcuts (long-press launcher icon) — see res/xml/shortcuts.xml -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
            <!--
              Verified App Links (Android's counterpart to iOS Universal Links,
              scoped identically — see the AASA comment in
              public/.well-known/assetlinks.json's sibling apple-app-site-association).
              Android intent-filters can't match on query params like iOS's AASA
              "components" can, so this narrows by exact path instead: only "/",
              "/en" and "/en/" ever carry a place-detail deep link (selectLat=…);
              every other path (SEO city/category pages, static pages) is left out,
              so those keep opening in the browser. @capacitor/app already fires
              "appUrlOpen" for a matching ACTION_VIEW intent on Android — the
              existing web-side listener (app/HomeClient.tsx) handles the rest,
              no native Java change needed.
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="accessible-places.org" android:path="/" />
                <data android:scheme="https" android:host="accessible-places.org" android:path="/en" />
                <data android:scheme="https" android:host="accessible-places.org" android:path="/en/" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Native foreground geolocation (Nearby search) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
</manifest>
